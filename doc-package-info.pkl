/// Typed PKL schema for authoring YAMA (Yet Another Metadata Application Profile
/// and RDF Mapping Language) profiles. Provides editor autocomplete, authoring-time
/// validation, and modular composition for YAMAML documents.
///
/// See <https://docs.yamaml.org/specs/yamaml/pkl> for usage documentation.
amends "pkl:DocPackageInfo"

name = "yama"
version = "0.1.0"
importUri = "package://pkg.pkl-lang.org/github.com/yamaml/yama-pkl/yama@0.1.0#/"
sourceCode = "https://github.com/yamaml/yama-pkl"
sourceCodeUrlScheme = "https://github.com/yamaml/yama-pkl/blob/yama@\(version)%{path}#L%{line}-L%{endLine}"
issueTracker = "https://github.com/yamaml/yama-pkl/issues"
authors {
  "Nishad Thalhath <nishad@users.noreply.github.com>"
}
